# ── Property-FInder Agent (frontend / conversational) ─────────────────────
# Required: agent identity (e.g. 32-char hex). Same seed = same agent address.
AGENT_SECRET_KEY_1=your_agent_seed_here_32_chars

# Required for Mailbox (ASI1/Agentverse delivery). Get from https://agentverse.ai
AGENTVERSE_API_KEY=your_agentverse_api_key

# Required for Repliers MLS listings. Get from Repliers.
REPLIERS_API_KEY=your_repliers_api_key

# Optional: ASI:One API key. When set, "create a Google Sheet" requests are delegated to the platform (like CHAI) so no Google credentials are needed for that.
# Get from ASI:One Platform → Developer → Create New. Supports ASI1_API_KEY or ASI_ONE_API_KEY.
# ASI1_API_KEY=your_asi1_api_key

# Optional: OpenAI API key for richer natural-language understanding.
# If not set, the agent falls back to simple regex parsing.
OPENAI_API_KEY=your_openai_api_key
# Optional: override OpenAI model (default: gpt-4.1-mini)
# OPENAI_MODEL=gpt-4.1-mini

# Optional: use Mailbox (no public URL). Set to false to use AGENT_ENDPOINT_URL.
USE_MAILBOX=true

# Optional: local port (default 8000). Use another port (e.g. 8001) if 8000 is in use.
AGENT_PORT=8000

# Optional: only when USE_MAILBOX=false (e.g. ngrok URL).
# AGENT_ENDPOINT_URL=https://xyz.ngrok-free.app

# Optional: Email wishlist export (Resend). If set, "export wishlist" emails the full details.
# EMAIL_API_KEY=re_...
# Optional default recipient if user doesn't specify one in chat:
# EMAIL_TO=you@example.com

# Optional: Stripe (Payment Protocol). When set, full listing "details" AND full reports
# require a small payment before delivery.
# Use Stripe test keys for development (https://dashboard.stripe.com/test/apikeys).
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# Amount in cents (default 50 = $0.50 for details; increase for full reports e.g. 199 = $1.99).
# STRIPE_AMOUNT_CENTS=199
# STRIPE_CURRENCY=usd
# STRIPE_PRODUCT_NAME=Property Report
# STRIPE_SUCCESS_URL=https://agentverse.ai

# ── Real Estate Report Agent (backend / deep research) ────────────────────
# Unique seed for the second agent. Must be different from AGENT_SECRET_KEY_1.
# AGENT_SECRET_KEY_2=your_second_agent_seed_32_chars
# Port for the Report Agent (default 8001, so it doesn't clash with port 8000).
# RE_AGENT_PORT=8001
# After running run_real_estate_agent.py once, copy the printed address here:
# REAL_ESTATE_AGENT_ADDRESS=agent1...

# Google Sheets OAuth (required for full report spreadsheet creation).
# Create an OAuth 2.0 Client ID (Desktop app) at https://console.cloud.google.com/
# Then either paste the JSON inline or point to the file:
# GOOGLE_OAUTH_CLIENT_JSON={"installed":{"client_id":"...","client_secret":"...",...}}
# GOOGLE_OAUTH_CLIENT_FILE=client_secrets.json
# User ID under which sheets are created (any stable string, e.g. "report_agent").
# GOOGLE_SHEET_USER_ID=report_agent
# Optional: share every created sheet as writer with this email.
# GOOGLE_SHEET_SHARE_EMAIL=you@example.com
