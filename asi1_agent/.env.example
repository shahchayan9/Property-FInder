# Required: agent identity (e.g. 32-char hex). Same seed = same agent address.
AGENT_SECRET_KEY_1=your_agent_seed_here_32_chars

# Required for Mailbox (ASI1/Agentverse delivery). Get from https://agentverse.ai
AGENTVERSE_API_KEY=your_agentverse_api_key

# Required for Repliers MLS listings. Get from Repliers.
REPLIERS_API_KEY=your_repliers_api_key

# Optional: ASI:One API key. When set, "create a Google Sheet" requests are delegated to the platform (like CHAI) so no Google credentials are needed for that.
# Get from ASI:One Platform → Developer → Create New. Supports ASI1_API_KEY or ASI_ONE_API_KEY.
# ASI1_API_KEY=your_asi1_api_key

# Optional: OpenAI API key for richer natural-language understanding.
# If not set, the agent falls back to simple regex parsing.
OPENAI_API_KEY=your_openai_api_key
# Optional: override OpenAI model (default: gpt-4.1-mini)
# OPENAI_MODEL=gpt-4.1-mini

# Optional: use Mailbox (no public URL). Set to false to use AGENT_ENDPOINT_URL.
USE_MAILBOX=true

# Optional: local port (default 8000). Use another port (e.g. 8001) if 8000 is in use.
AGENT_PORT=8000

# Optional: only when USE_MAILBOX=false (e.g. ngrok URL).
# AGENT_ENDPOINT_URL=https://xyz.ngrok-free.app

# Optional: Google Sheets export. If set, each search creates a new sheet with full results and the link is added to the chat reply.
# Path to service account JSON (Google Cloud Console → IAM → Service accounts → Create key). Needs Sheets + Drive API enabled.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json
# Or: GOOGLE_SHEETS_CREDENTIALS_PATH=/path/to/your-service-account.json
# How many listings to fetch for the sheet (default 50). Chat still shows top 3.
# GOOGLE_SHEETS_EXPORT_PAGE_SIZE=50
